pages = {7-23},
year = {2002},
note = {TOSCA 2001, Theory of Concurrency, Higher Order Languages and Types},
issn = {1571-0661},
doi = {https://doi.org/10.1016/S1571-0661(04)00316-0},
url = {https://www.sciencedirect.com/science/article/pii/S1571066104003160},
author = {Flemming Nielson and Hanne Riis Nielson and Helmut Seidl},
abstract = {The spi-calculus is a variant of the polyadic π-calculus that admits symmetric cryptography and that admits expressing communication protocols in a precise though still abstract way. This paper shows that context-independent control flow analysis can be calculated in cubic time despite the fact that the spi-calculus operates over an infinite universe of values. Our approach is based on Horn Clauses with Sharing and we develop transformations to pass from the infinite to the finite and to deal with the polyadic nature of input and output. We prove that this suffices for obtaining a cubic time implementation without sacrificing precision and without making simplifying assumptions on the nature of keys.}
}
@InProceedings{tagged_bounded_secrecy,
author="Ramanujam, R.
